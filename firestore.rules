
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SportSphere Security Rules
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a strict user-ownership and shared-collaboration model. Access 
     * is primarily governed by matching authenticated user IDs against path parameters or 
     * denormalized ownership fields within documents.
     *
     * DATA STRUCTURE:
     * - /userProfiles/{userId}: Private user information.
     * - /listings/{listingId}: Publicly discoverable active listings.
     * - /articles/{articleId}: Publicly readable news/insights.
     * - /userProfiles/{userId}/providerListings/{listingId}: Private/Draft listings owned by a provider.
     * - /bookingRequests/{bookingRequestId}: Shared documents between a requester and a provider.
     * - /messages/{messageId}: Shared communication documents between a sender and a receiver.
     */

    // --- Helper Functions ---

    /** Checks if a user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches a specific ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Verifies ownership and ensures the document exists for state-changing operations. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** Checks if the authenticated user is one of two participants in a shared document. */
    function isParticipant(id1, id2) {
      return isSignedIn() && (request.auth.uid == id1 || request.auth.uid == id2);
    }

    /** Verifies participation and ensures the document exists for state-changing operations. */
    function isExistingParticipant(id1, id2) {
      return resource != null && isParticipant(id1, id2);
    }

    // --- Collection Rules ---

    match /userProfiles/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      match /providerListings/{listingId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.providerId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.providerId == resource.data.providerId;
        allow delete: if isExistingOwner(userId);
      }
    }

    match /listings/{listingId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.providerId == request.auth.uid;
      allow update: if resource != null && resource.data.providerId == request.auth.uid && request.resource.data.providerId == resource.data.providerId;
      allow delete: if resource != null && resource.data.providerId == request.auth.uid;
    }

    match /articles/{articleId} {
      allow get, list: if true;
      allow write: if false; // Articles are managed via Admin/CMS (not in client MVP)
    }

    match /bookingRequests/{bookingRequestId} {
      allow get: if isParticipant(resource.data.requesterId, resource.data.providerId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.requesterId == request.auth.uid;
      allow update: if isExistingParticipant(resource.data.requesterId, resource.data.providerId) && request.resource.data.requesterId == resource.data.requesterId;
      allow delete: if isExistingParticipant(resource.data.requesterId, resource.data.providerId);
    }

    match /messages/{messageId} {
      allow get: if isParticipant(resource.data.senderId, resource.data.receiverId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update: if isExistingParticipant(resource.data.senderId, resource.data.receiverId) && request.resource.data.senderId == resource.data.senderId;
      allow delete: if isExistingParticipant(resource.data.senderId, resource.data.receiverId);
    }
  }
}
